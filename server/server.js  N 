const express = require("express");
const http = require("http");
const { Server } = require("socket.io");
const fs = require("fs");
const cors = require("cors");

const app = express();
const server = http.createServer(app);
const io = new Server(server);

app.use(cors());
app.use(express.json());
app.use(express.static("../client"));

const DATA_FILE = "../data/gameState.json";

let gameState = {
  status: "NOT_STARTED",
  maxTickets: 30,
  tickets: [],
  calledNumbers: [],
  currentNumber: null
};

if (fs.existsSync(DATA_FILE)) {
  gameState = JSON.parse(fs.readFileSync(DATA_FILE));
}

function saveState() {
  fs.writeFileSync(DATA_FILE, JSON.stringify(gameState, null, 2));
}

let numberPool = [];
let interval = null;

function generateNumbers() {
  return Array.from({ length: 90 }, (_, i) => i + 1)
    .sort(() => Math.random() - 0.5);
}

function startCalling() {
  interval = setInterval(() => {
    if (numberPool.length === 0) {
      clearInterval(interval);
      gameState.status = "ENDED";
      saveState();
      io.emit("update", gameState);
      return;
    }

    const next = numberPool.pop();
    gameState.calledNumbers.push(next);
    gameState.currentNumber = next;

    saveState();
    io.emit("update", gameState);

  }, 3000);
}

io.on("connection", (socket) => {

  socket.emit("update", gameState);

  socket.on("startGame", () => {
    if (gameState.status !== "RUNNING") {

      if (gameState.maxTickets > 30) {
        gameState.maxTickets = 30;
      }

      gameState.tickets = [];
      numberPool = generateNumbers();
      gameState.calledNumbers = [];
      gameState.currentNumber = null;
      gameState.status = "RUNNING";

      startCalling();
      saveState();
      io.emit("update", gameState);
    }
  });

  socket.on("setMaxTickets", (value) => {
    if (gameState.status === "NOT_STARTED") {
      gameState.maxTickets = Math.min(30, Math.max(1, value));
      saveState();
      io.emit("update", gameState);
    }
  });

  socket.on("endGame", () => {
    gameState.status = "ENDED";
    clearInterval(interval);
    saveState();
    io.emit("update", gameState);
  });

});

server.listen(3000, () => {
  console.log("Tambola server running on port 3000");
});
